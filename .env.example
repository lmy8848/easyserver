# EasyServer Environment Variables

# JWT Secret (required in production)
EASYSERVER_JWT_SECRET=your-secret-key-here

# Deploy Encryption Key (required for SSH credential encryption)
EASYSERVER_ENCRYPTION_KEY=your-32-byte-encryption-key

# Server
EASYSERVER_PORT=8080
EASYSERVER_HOST=0.0.0.0

# TLS
EASYSERVER_TLS_ENABLED=false
EASYSERVER_TLS_CERT_FILE=
EASYSERVER_TLS_KEY_FILE=

# Database
EASYSERVER_DB_PATH=./data/easyserver.db

# Monitor
EASYSERVER_MONITOR_INTERVAL=1s
EASYSERVER_MONITOR_RETENTION=24h

# Tencent Cloud (optional)
EASYSERVER_TENCENTCLOUD_ENABLED=false
EASYSERVER_TENCENTCLOUD_SECRET_ID=
EASYSERVER_TENCENTCLOUD_SECRET_KEY=
EASYSERVER_TENCENTCLOUD_REGION=ap-guangzhou
EASYSERVER_TENCENTCLOUD_INSTANCE_ID=
