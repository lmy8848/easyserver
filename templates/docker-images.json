      "images": [
        { "name": "RabbitMQ", "image": "rabbitmq:management", "description": "消息队列", "ports": ["5672:5672", "15672:15672"] },
        { "name": "Kafka", "image": "bitnami/kafka:latest", "description": "分布式消息流", "ports": ["9092:9092"] }
      ]
    },
    {
      "name": "监控",
      "images": [
