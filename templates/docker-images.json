      "name": "Web 服务器",
      "images": [
        { "name": "Nginx", "image": "nginx:latest", "description": "高性能 HTTP 服务器", "ports": ["80:80", "443:443"] },
        { "name": "Apache", "image": "httpd:latest", "description": "Apache HTTP 服务器", "ports": ["80:80"] },
