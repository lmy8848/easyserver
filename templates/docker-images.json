      "images": [
        { "name": "MySQL 8", "image": "mysql:8", "description": "流行的关系型数据库", "ports": ["3306:3306"], "env": {"MYSQL_ROOT_PASSWORD": "changeme"}, "volumes": ["mysql-data:/var/lib/mysql"] },
        { "name": "PostgreSQL 16", "image": "postgres:16", "description": "强大的开源数据库", "ports": ["5432:5432"], "env": {"POSTGRES_PASSWORD": "changeme"}, "volumes": ["pg-data:/var/lib/postgresql/data"] },
        { "name": "Redis 7", "image": "redis:7-alpine", "description": "内存数据库/缓存", "ports": ["6379:6379"], "volumes": ["redis-data:/data"] },
        { "name": "MongoDB 7", "image": "mongo:7", "description": "NoSQL 文档数据库", "ports": ["27017:27017"], "env": {"MONGO_INITDB_ROOT_PASSWORD": "changeme"}, "volumes": ["mongo-data:/data/db"] },
        { "name": "MariaDB", "image": "mariadb:latest", "description": "MySQL 分支", "ports": ["3306:3306"], "env": {"MARIADB_ROOT_PASSWORD": "changeme"}, "volumes": ["mariadb-data:/var/lib/mysql"] }
      ]
    },
    {
      "name": "缓存",
      "images": [
