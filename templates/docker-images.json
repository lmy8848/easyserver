        { "name": "Adminer", "image": "adminer:latest", "description": "数据库管理工具", "ports": ["8080:8080"] },
        { "name": "phpMyAdmin", "image": "phpmyadmin:latest", "description": "MySQL 管理工具", "ports": ["8080:80"] },
        { "name": "Nginx Proxy Manager", "image": "jc21/nginx-proxy-manager:latest", "description": "Nginx 反向代理管理", "ports": ["80:80", "443:443", "81:81"] }
